   "source": [
    "#!/home/ouail.kerrak/.conda/envs/ood310/bin/python\n",
    "\n",
    "\n",
    "import os\n",
    "import sys\n",
    "\n",
    "_env = os.environ.get('CONDA_DEFAULT_ENV', '')\n",
    "if _env != 'ood310':\n",
    "    print(f'ERROR: wrong environment \"{_env}\". '\n",
    "          f'Run: conda activate ood310 && python {sys.argv[0]}')\n",
    "    sys.exit(1)\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as ticker\n",
    "from pathlib import Path\n",
    "from PIL import Image\n",
    "from scipy.fftpack import dct\n",
    "from tqdm import tqdm\n",
    "\n",
    "# ── Paths ─────────────────────────────────────────────────────────────────────\n",
    "PROJECT_ROOT = Path('/home/ouail.kerrak/ood_project')\n",
    "DATA_DIR     = PROJECT_ROOT / 'data'\n",
    "OUTPUT_DIR   = PROJECT_ROOT / 'plots'\n",
    "OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "ID_IMGLIST   = DATA_DIR / 'benchmark_imglist/autonomous/bdd100k/val_13cls.txt'\n",
    "ID_IMG_DIR   = DATA_DIR / 'id/bdd100k/bdd100k/bdd100k/images/'\n",
    "\n",
    "OOD_IMGLIST  = DATA_DIR / 'benchmark_imglist/autonomous/smiyc/test.txt'\n",
    "OOD_IMG_DIR  = DATA_DIR / 'ood/far/SMIYC/test/images'\n",
    "\n",
    "# Number of images to sample for the plot (more = smoother, slower)\n",
    "N_ID_SAMPLES  = 400\n",
    "N_OOD_SAMPLES = 400\n",
    "\n",
    "\n",
    "# ── Benford's Law theoretical distribution ────────────────────────────────────\n",
    "BENFORD = np.array([np.log10(1 + 1/d) for d in range(1, 10)])\n",
    "DIGITS  = np.arange(1, 10)\n",
    "\n",
    "\n",
    "# ── Helpers ───────────────────────────────────────────────────────────────────\n",
    "def load_imglist(path, n=None):\n",
    "    images = []\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            parts = line.strip().split()\n",
    "            if parts:\n",
    "                images.append(parts[0])\n",
    "            if n and len(images) >= n:\n",
    "                break\n",
    "    return images\n",
    "\n",
    "\n",
    "def get_first_digit(x):\n",
    "    x = abs(float(x))\n",
    "    if x == 0:\n",
    "        return None\n",
    "    while x < 1:   x *= 10\n",
    "    while x >= 10: x /= 10\n",
    "    return int(x)\n",
    "\n",
    "\n",
    "def compute_digit_distribution(img_path, block_size=8):\n",
    "    \"\"\"\n",
    "    Compute normalised first-digit histogram of DCT coefficients\n",
    "    for a single image. Returns np.array of shape [9].\n",
    "    \"\"\"\n",
    "    try:\n",
    "        img  = Image.open(img_path).convert('L')\n",
    "        img  = img.resize((224, 224))\n",
    "        arr  = np.array(img, dtype=np.float64)\n",
    "        h, w = arr.shape\n",
    "        digits = []\n",
    "\n",
    "        for row in range(0, h - block_size + 1, block_size):\n",
    "            for col in range(0, w - block_size + 1, block_size):\n",
    "                block     = arr[row:row+block_size, col:col+block_size]\n",
    "                dct_block = dct(dct(block.T, norm='ortho').T, norm='ortho')\n",
    "                ac        = dct_block.flatten()[1:]   # exclude DC\n",
    "                for coeff in ac:\n",
    "                    d = get_first_digit(coeff)\n",
    "                    if d is not None:\n",
    "                        digits.append(d)\n",
    "\n",
    "        if len(digits) < 100:\n",
    "            return None\n",
    "\n",
    "        counts = np.zeros(9)\n",
    "        for d in digits:\n",
    "            counts[d - 1] += 1\n",
    "        return counts / counts.sum()\n",
    "\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "\n",
    "def aggregate_distributions(img_paths, img_dir, desc=''):\n",
    "    \"\"\"\n",
    "    Average the first-digit distributions across all images.\n",
    "    Returns mean and std across images, shape [9].\n",
    "    \"\"\"\n",
    "    all_dists = []\n",
    "    for p in tqdm(img_paths, desc=f'  Computing DCT [{desc}]'):\n",
    "        full = Path(img_dir) / p\n",
    "        dist = compute_digit_distribution(full)\n",
    "        if dist is not None:\n",
    "            all_dists.append(dist)\n",
    "\n",
    "    all_dists = np.array(all_dists)   # [N, 9]\n",
    "    return all_dists.mean(axis=0), all_dists.std(axis=0)\n",
    "\n",
    "# In aggregate_distributions, find the single most anomalous image\n",
    "def find_most_anomalous(img_paths, img_dir, desc=''):\n",
    "    best_chi2 = -1\n",
    "    best_dist = None\n",
    "    for p in tqdm(img_paths, desc=f'  Finding most anomalous [{desc}]'):\n",
    "        full = Path(img_dir) / p\n",
    "        dist = compute_digit_distribution(full)\n",
    "        if dist is None:\n",
    "            continue\n",
    "        n = 784 * 63\n",
    "        chi2 = n * np.sum((dist - BENFORD)**2 / BENFORD)\n",
    "        if chi2 > best_chi2:\n",
    "            best_chi2 = chi2\n",
    "            best_dist = dist\n",
    "            best_path = p\n",
    "    print(f'  Most anomalous: {best_path}  χ²={best_chi2:.2f}')\n",
    "    return best_dist\n",
    "\n",
    "\n",
    "# ── Main ──────────────────────────────────────────────────────────────────────\n",
    "def main():\n",
    "    print('Computing Benford distributions from real images...')\n",
    "    print(f'  ID  samples: {N_ID_SAMPLES} from BDD100K-val')\n",
    "    print(f'  OOD samples: {N_OOD_SAMPLES} from StreetHazards')\n",
    "\n",
    "    id_paths  = load_imglist(ID_IMGLIST,  n=N_ID_SAMPLES)\n",
    "    ood_paths = load_imglist(OOD_IMGLIST, n=N_OOD_SAMPLES)\n",
    "\n",
    "    id_mean,  id_std  = aggregate_distributions(id_paths,  ID_IMG_DIR,  'BDD100K')\n",
    "    ood_mean = find_most_anomalous(ood_paths, OOD_IMG_DIR, 'SMIYC')\n",
    "    ood_std  = np.zeros(9)\n",
    "\n",
    "    # ── Print χ² for both ────────────────────────────────────────────────────\n",
    "    def chi2(dist):\n",
    "        n = 784 * 63   # approx number of AC coefficients per image\n",
    "        return n * np.sum((dist - BENFORD)**2 / BENFORD)\n",
    "\n",
    "    print(f'\\n  BDD100K   mean χ²: {chi2(id_mean):.2f}')\n",
    "    print(f'  StreetHazards mean χ²: {chi2(ood_mean):.2f}')\n",
    "    print(f'  (OOD χ² should be higher)')\n",
    "\n",
    "    # ── Plot ─────────────────────────────────────────────────────────────────\n",
    "    matplotlib.rcParams.update({\n",
    "        'font.family':      'serif',\n",
    "        'font.size':        12,\n",
    "        'axes.titlesize':   13,\n",
    "        'axes.labelsize':   12,\n",
    "        'legend.fontsize':  11,\n",
    "        'xtick.labelsize':  11,\n",
    "        'ytick.labelsize':  11,\n",
    "        'figure.dpi':       150,\n",
    "        'axes.grid':        True,\n",
    "        'grid.linestyle':   '--',\n",
    "        'grid.alpha':       0.4,\n",
    "    })\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=(8, 5))\n",
    "\n",
    "    # Theoretical Benford curve\n",
    "    ax.plot(DIGITS, BENFORD,\n",
    "            color='black', linewidth=2.5, label=\"Theoretical Benford's Law\",\n",
    "            zorder=5)\n",
    "\n",
    "    # ID distribution with shaded std band\n",
    "    ax.plot(DIGITS, id_mean,\n",
    "            color='#1f77b4', linewidth=1.8, linestyle='--',\n",
    "            marker='o', markersize=6,\n",
    "            label='Natural image (in-distribution)', zorder=4)\n",
    "    ax.fill_between(DIGITS,\n",
    "                    id_mean - id_std, id_mean + id_std,\n",
    "                    color='#1f77b4', alpha=0.12)\n",
    "\n",
    "    # OOD distribution with shaded std band\n",
    "    ax.plot(DIGITS, ood_mean,\n",
    "            color='#d62728', linewidth=1.8, linestyle=':',\n",
    "            marker='x', markersize=7, markeredgewidth=2,\n",
    "            label='OOD / anomalous image', zorder=4)\n",
    "    ax.fill_between(DIGITS,\n",
    "                    ood_mean - ood_std, ood_mean + ood_std,\n",
    "                    color='#d62728', alpha=0.10)\n",
    "\n",
    "    ax.set_xlabel('Leading digit (d)')\n",
    "    ax.set_ylabel('Probability P(d)')\n",
    "    ax.set_xticks(DIGITS)\n",
    "    ax.set_xlim(0.7, 9.3)\n",
    "    ax.set_ylim(0, max(ood_mean.max(), id_mean.max(), BENFORD.max()) + 0.04)\n",
    "    ax.yaxis.set_major_formatter(ticker.FormatStrFormatter('%.2f'))\n",
    "    ax.legend(framealpha=0.9)\n",
    "\n",
    "    plt.tight_layout()\n",
    "\n",
    "    pdf_path = OUTPUT_DIR / 'benford_distribution.pdf'\n",
    "    png_path = OUTPUT_DIR / 'benford_distribution.png'\n",
    "    plt.savefig(pdf_path, bbox_inches='tight')\n",
    "    plt.savefig(png_path, bbox_inches='tight', dpi=200)\n",
    "    print(f'\\n  ✓ Saved: {pdf_path}')\n",
    "    print(f'  ✓ Saved: {png_path}')\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    main()"
   ]
  },
